# 1claw agent credentials
# Get this from the enrollment approval page or email.
# Agent ID and vault are auto-discovered from the key — no extra vars needed.
ONECLAW_AGENT_API_KEY=ocv_...

# Optional overrides (only needed in advanced setups):
# ONECLAW_AGENT_ID=<agent-uuid>
# ONECLAW_VAULT_ID=<vault-uuid>
# ONECLAW_BASE_URL=https://api.1claw.xyz
